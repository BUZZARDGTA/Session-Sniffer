{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "🚀 Launch Session Sniffer",
            "type": "shell",
            "command": "${workspaceFolder}/.venv/Scripts/python.exe",
            "args": ["-m", "session_sniffer"],
            "options": {
                "env": {
                    "PYTHONPATH": "${workspaceFolder}/src"
                }
            },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": true,
                "panel": "new",
                "clear": true

            }
        },
        {
            "label": "🔍 Run All Quality Checks",
            "type": "shell",
            "command": "powershell.exe",
            "args": ["-ExecutionPolicy", "Bypass", "-File", "${workspaceFolder}/code-quality-checks.ps1"],
            "group": {
                "kind": "test",
                "isDefault": true
            },
            "presentation": {
                "echo": true,
                "reveal": "always",
                "panel": "shared",
                "clear": true
            }
        },
        {
            "label": "📦 Install Dependencies",
            "type": "shell",
            "command": "${workspaceFolder}/.venv/Scripts/pip",
            "args": ["install", "-e", ".[dev]"],
            "group": "build",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "panel": "shared"
            }
        },
        {
            "label": "🔄 Check Dependencies",
            "type": "shell",
            "command": "powershell.exe",
            "args": ["-ExecutionPolicy", "Bypass", "-File", "${workspaceFolder}/check_dependencies.ps1"],
            "group": "build",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": true,
                "panel": "new",
                "clear": true
            }
        },
        {
            "label": "⚡ Ruff - Fast Python Linter",
            "type": "shell",
            "command": "${workspaceFolder}/.venv/Scripts/ruff.exe",
            "args": ["check", ".", "--config", "pyproject.toml"],
            "group": "test",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "panel": "shared"
            }
        },
        {
            "label": "📝 Flake8 - Style Guide Enforcer",
            "type": "shell",
            "command": "${workspaceFolder}/.venv/Scripts/flake8.exe",
            "args": [".", "--config", ".flake8"],
            "group": "test",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "panel": "shared"
            }
        },
        {
            "label": "🧹 Pylint - Code Quality Analyzer",
            "type": "shell",
            "command": "${workspaceFolder}/.venv/Scripts/pylint.exe",
            "args": [".", "--rcfile", "pyproject.toml"],
            "group": "test",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "panel": "shared"
            }
        },
        {
            "label": "🦅 Vulture - Dead Code Detector",
            "type": "shell",
            "command": "${workspaceFolder}/.venv/Scripts/vulture.exe",
            "args": [".", "--config", "pyproject.toml"],
            "group": "test",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "panel": "shared"
            }
        },
        {
            "label": "🎯 Pyright - Microsoft Type Checker",
            "type": "shell",
            "command": "${workspaceFolder}/.venv/Scripts/pyright.exe",
            "args": [".", "--project", "pyproject.toml"],
            "group": "test",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "panel": "shared"
            }
        },
        {
            "label": "🔬 MyPy - Static Type Checker",
            "type": "shell",
            "command": "${workspaceFolder}/.venv/Scripts/mypy.exe",
            "args": [".", "--config-file", "pyproject.toml"],
            "group": "test",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "panel": "shared"
            }
        },
        {
            "label": "🧪 Ty - Type Checker",
            "type": "shell",
            "command": "${workspaceFolder}/.venv/Scripts/ty.exe",
            "args": ["check", "."],
            "group": "test",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "panel": "shared"
            }
        },
        {
            "label": "🔐 Pip Audit - Vulnerability Scanner",
            "type": "shell",
            "command": "${workspaceFolder}/.venv/Scripts/pip-audit.exe",
            "args": ["--local", "--skip-editable"],
            "group": "test",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "panel": "shared"
            }
        },
        {
            "label": "🛡️ Safety - Security Vulnerability Check",
            "type": "shell",
            "command": "${workspaceFolder}/.venv/Scripts/safety.exe",
            "args": ["scan"],
            "group": "test",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "panel": "shared"
            }
        },
        {
            "label": "🐍 Snyk - Developer Security Platform",
            "type": "shell",
            "command": "powershell.exe",
            "args": ["-Command", "& \"${workspaceFolder}/.venv/Scripts/Activate.ps1\"; snyk test"],
            "group": "test",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "panel": "shared"
            }
        }
    ]
}