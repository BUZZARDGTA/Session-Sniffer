{
    "files.exclude": {
        ".dccache": true,
        ".venv": true,
        "**/__pycache__": true,
        "**/.history": true,
        "**/.mypy_cache": true,
        "**/.pytest_cache": true,
        "**/.ruff_cache": true,
        "**/*.pyc": true,
        "**/*.pyd": true,
        "**/*.pyo": true,
        "**/build": true,
        "**/dist": true,
        "bin": true,
        "COPYING": true,
        "resources": true,
        "Session_Sniffer.exe": true
    },
    "python.terminal.activateEnvironment": true,
    "python.terminal.activateEnvInCurrentTerminal": true,
    "pylint.enabled": true,
    "pylint.path": [
        "${workspaceFolder}/.venv/Scripts/pylint.exe"
    ],
    "pylint.args": [
        "--rcfile",
        "${workspaceFolder}/pyproject.toml"
    ],
    "pylint.severity": {
        "convention": "Warning",
        "refactor": "Warning",
        "warning": "Warning",
        "error": "Error",
        "fatal": "Error",
        "info": "Information"
    },
    "search.useIgnoreFiles": false,
    "extensions.ignoreRecommendations": false,
    "snyk.advanced.autoSelectOrganization": true,
    "snyk.advanced.organization": "eb736547-7db6-4fd5-93e4-acf89de308a3",
    "ruff.interpreter": [
        "${workspaceFolder}/.venv/Scripts/python.exe"
    ],
    "python.defaultInterpreterPath": "${workspaceFolder}/.venv/Scripts/python.exe",
    "terminal.integrated.profiles.windows": {
        "PowerShell (.venv)": {
            "source": "PowerShell",
            "args": [
                "-NoExit",
                "-ExecutionPolicy",
                "Bypass",
                "-Command",
                "& '${workspaceFolder}/.venv/Scripts/Activate.ps1'"
            ]
        }
    },
    "terminal.integrated.defaultProfile.windows": "PowerShell (.venv)",
    "terminal.integrated.automationProfile.windows": {
        "path": "powershell.exe",
        "args": [
            "-ExecutionPolicy",
            "Bypass"
        ]
    },
    "python.analysis.typeCheckingMode": "strict",
    "python.analysis.extraPaths": [
        "src"
    ],
    "python.analysis.diagnosticSeverityOverrides": {
        "reportUnknownVariableType": "warning",
        "reportUnknownMemberType": "warning",
        "reportUnknownArgumentType": "warning",
        "reportUnknownLambdaType": "warning",
        "reportUnknownParameterType": "warning",
        "reportUnknownReturnType": "warning"
    },
    "terminal.integrated.scrollback": 10000,
    "python-envs.pythonProjects": [
        {
            "path": ".",
            "envManager": "ms-python.python:venv",
            "packageManager": "ms-python.python:pip"
        }
    ]
}